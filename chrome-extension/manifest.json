{
  "manifest_version": 3,
  "name": "WebIntel",
  "version": "1.0.0",
  "description": "Instant domain intelligence — see competitor data, brand profiles, and market insights for any website you visit.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://webintel.diyaaaa.in/*", "https://dash.webintel.diyaaaa.in/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
